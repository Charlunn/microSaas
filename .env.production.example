# Domain / routing
APP_BASE_DOMAIN=yourdomain.com
APP_HTTP_PORT=80

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.host:5432/postgres

# Admin API auth
ADMIN_API_TOKEN=replace-with-strong-token
ADMIN_API_SCOPES=apps:read,apps:write,deploy:read,deploy:write,domains:write

# Optional
ARTIFACT_MAX_BYTES=52428800
DEPLOY_RUNNER_CWD=/workspace
