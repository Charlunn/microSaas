{
  "name": "micro-saas-factory",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "generate:child": "tsx scripts/generate-child-app.ts",
    "docker:up": "docker compose --env-file .env.production up -d --build main-landing reverse-proxy",
    "docker:down": "docker compose --env-file .env.production down",
    "docker:logs": "docker compose --env-file .env.production logs -f --tail=200 main-landing reverse-proxy",
    "docker:ps": "docker compose --env-file .env.production ps"
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
